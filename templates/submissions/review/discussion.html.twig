{% macro vote_link(submission, post, positive) %}
    {% set has_voted = positive ? post.upvotedBy(app.user) : post.downvotedBy(app.user) %}
    {% set color_class = positive ? 'text-success' : 'text-danger' %}
    {% set symbol_class = positive ? 'fa-circle-up' : 'fa-circle-down' %}

    {% if app.user !== post.user %}
        <a href="{{ path('route_vote_post', {id: submission.id, postId: post.id, positive: positive}) }}">
            {#- -#}
            <i class="{% if has_voted %}{{ color_class }} fa-solid{% else %}text-secondary fa-regular{% endif %} {{ symbol_class }}"></i>
            {#- -#}
        </a>
    {% endif %}
{% endmacro %}

{% for topic_items in topics %}
    {% set topic = topic_items.entity %}
    {% set response_form = topic_items.response_form %}

    <div class="card mb-2">
        <div class="card-header">
            <strong>{{ topic.user.nickname }}</strong>
            wrote on {{ topic.postedUtc|fragile_datetime_utc }}
            <span class="text-body-tertiary">(#{{ topic.id }})</span>

            {{ _self.vote_link(submission, topic, 1) }}
            {% if topic.upvotesCount > 0 %}+{{ topic.upvotesCount }}{% endif %}

            {{ _self.vote_link(submission, topic, 0) }}
            {% if topic.downvotesCount > 0 %}-{{ topic.downvotesCount }}{% endif %}
        </div>

        <div class="card-body">{{ topic.message|nl2br }}</div>

        {% if topic.responses is not empty %}
            <div class="card-body ps-5 pb-0">
                {% for response in topic.responses %}
                    <p class="mb-1">
                        <strong>{{ response.user.nickname }}</strong>
                        responded on {{ response.postedUtc|fragile_datetime_utc }}
                        <span class="text-body-tertiary">(#{{ response.id }})</span>

                        {{ _self.vote_link(submission, response, 1) }}
                        {% if response.upvotesCount > 0 %}+{{ response.upvotesCount }}{% endif %}

                        {{ _self.vote_link(submission, response, 0) }}
                        {% if response.downvotesCount > 0 %}-{{ response.downvotesCount }}{% endif %}
                    </p>

                    <p>{{ response.message|nl2br }}</p>
                {% endfor %}
            </div>
        {% endif %}

        <div class="card-body ps-5">
            {{ form_start(response_form) }}
            {{ form_widget(response_form.message) }}
            {{ form_errors(response_form.message) }}
            <button type="submit" class="btn btn-primary btn-sm mt-2">Respond</button>
            {{ form_end(response_form) }}
        </div>
    </div>
{% endfor %}

<div class="card">
    <div class="card-header">
        Start new topic
    </div>

    <div class="card-body">
        {{ form_start(new_topic_form) }}
        {{ form_widget(new_topic_form.message) }}
        {{ form_errors(new_topic_form.message) }}
        <button type="submit" class="btn btn-primary btn-sm mt-2">Post</button>
        {{ form_end(new_topic_form) }}
    </div>
</div>
