{% extends 'submissions/_base.html.twig' %}

{% block title %}Submission #{{ importData.submission.id }}{% endblock %}

{% block body %}
    <h1>{{ block('title') }}</h1>

    {% if importData.matchedCreators|length > 1 %}
        <p>
            Matched multiple creators: {# grep-code-matched-multiple-creators #}

            {% for creator in importData.matchedCreators %}
                <a href="{{ path('rt_main', {_fragment: creator.lastCreatorId}) }}">{{ creator.name }} ({{ creator.lastCreatorId }})</a>
                {%- if loop.last %}.{% else %},{% endif %}
            {% endfor %}

            <span class="text-danger">Unable to continue.</span>
        </p>
    {% elseif importData.matchedCreators is empty %}
        <p>Adding a new creator.</p>
    {% else %}
        {% set creator = importData.matchedCreators|first %}

        <p>
            Updating: <a href="{{ path('rt_main', {_fragment: creator.lastCreatorId}) }}">{{ creator.name }} ({{ creator.lastCreatorId }})</a>.

            {% if '' != creator.inactiveReason %}
                <span id="creator-hidden-warning" class="badge bg-warning text-dark">Hidden</span>
            {% endif %}
        </p>
    {% endif %}

    {% if similarlyNamedCreators %}
        <p>
            Creators named similarly:

            {% for creator in similarlyNamedCreators %}
                <a href="{{ path('rt_main', {_fragment: creator.lastCreatorId}) }}">{{ creator.allNames|join(' / ') }} ({{ creator.lastCreatorId }})</a>
                {%- if loop.last %}.{% else %},{% endif %}
            {% endfor %}
        </p>
    {% endif %}

    {% if importData.submission.isUpdate != importData.isUpdate %}
        {# grep-code-legacy-submissions-with-no-creator-reference #}
        <p><span class="badge bg-warning text-dark">NOTE</span> This submission was originally an {% if importData.submission.isUpdate %}update{% else %}addition{% endif %}.</p>
    {% endif %}

    <div class="row">
        <div class="col-md-3">
            {{ form_errors(form) }}
            {{ form_start(form) }}

            {{ form_row(form.directives) }}
            {{ form_row(form.status) }}
            {{ form_row(form.comment) }}

            <div class="btn-group pe-3" role="group">
                {{ form_widget(form.save) }}
                {{ form_widget(form.save_and_close) }}
            </div>
            {{ form_widget(form.import) }}

            {{ form_rest(form) }}
            {{ form_end(form) }}

            <hr class="my-3">
            <button id="open-all-new-links" class="btn btn-info">Open all new links</button>
            <button class="ms-3 btn btn-info" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEmail"
                    aria-expanded="false" aria-controls="collapseEmail">
                <i class="fa-solid fa-at"></i>
            </button>

            <div class="collapse collapse mt-3" id="collapseEmail">
                <div class="card card-body">
                    <span class="user-select-all">{{ importData.submission.owner.email|default('No email :(') }}</span>
                </div>
            </div>
        </div>
        <div class="col-md-9">
            <table class="table table-sm" id="submission-manage">
                <thead>
                    <tr>
                        <th colspan="2">Field</th>
                        <th>Value</th>
                    </tr>
                </thead>

                <tbody>
                    {% for field in fields %}
                        {% set submitted_different = importData.submittedDifferent(field) %}
                        {% set fixes_applied = importData.fixesApplied(field) %}
                        {% set is_changing = importData.isChanging(field) %}

                        {% set row_class = (submitted_different ? 'submitted-different' : 'submitted-same')
                            ~ ' ' ~ (fixes_applied ? 'fixes-applied' : 'not-fixed')
                            ~ ' ' ~ (is_changing ? 'changing' : 'not-changing')
                            ~ ' ' ~ (field.isInIuForm ? 'in-iu-form' : 'automated')
                            ~ ' ' ~ (field.isFreeForm ? 'free-form' : 'structured')
                        %}

                        {% set new_value_class = importData.fixedData|is_valid(field) ? '' : 'table-danger' %}

                        <tr class="{{ row_class }}">
                            <th colspan="3">
                                {{ field.name }}
                            </th>
                        </tr>

                        {% if importData.isUpdate %}
                            <tr class="{{ field.value }} before {{ row_class }}">
                                <td>
                                    Old&nbsp;data
                                </td>
                                <td></td>
                                <td>
                                    {{ field|difference('danger', importData.subjectCreator, importData.fixedData)|link_urls }}
                                </td>
                            </tr>
                        {% endif %}

                        <tr class="{{ field.value }} submitted {{ row_class }}" data-field="{{ field.name }}" data-value="{{ importData.inputData.get(field)|as_str(true) }}">
                            <td>Submitted</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-secondary fix-button"><i class="fa-solid fa-screwdriver-wrench"></i></button>
                            </td>
                            <td>
                                {{ field|difference('primary', importData.inputData, importData.fixedData)|link_urls }}
                            </td>
                        </tr>

                        <tr class="{{ field.value }} after {{ row_class }}" data-field="{{ field.name }}" data-value="{{ importData.fixedData.get(field)|as_str(true) }}">
                            <td>New&nbsp;data</td>
                            <td class="text-end text-nowrap">
                                <button class="btn btn-sm btn-outline-warning clear-button"><i class="fa-solid fa-trash-can"></i></button>
                                <button class="btn btn-sm btn-outline-secondary fix-button"><i class="fa-solid fa-screwdriver-wrench"></i></button>
                            </td>
                            <td class="{{ new_value_class }}">
                                {{ field|difference('success', importData.fixedData, importData.subjectCreator)|link_urls }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
