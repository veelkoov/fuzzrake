{% extends '_base.html.twig' %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('user_password') }}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('user_password') }}
{% endblock %}

{% block title %}set your new password{% endblock %}

{% block body %}
    <h1 class="my-4">Set your new password</h1>

    {{ form_errors(reset_form) }}
    {{ form_start(reset_form) }}

    {{ form_row(reset_form.newPassword) }}
    <div class="mb-3">
        <p><span id="password-feedback"></span> <small id="password-explanation" class="text-body-secondary"></small></p>
    </div>

    <button class="btn btn-primary">Set password</button>
    {{ form_end(reset_form) }}
{% endblock %}
