{% extends '_base.html.twig' %}

{% block title %}contact{% endblock %}

{% block body %}
    <h1>
        <i class="fa-regular fa-envelope"></i> Contact
    </h1>

    <div class="alert alert-warning" role="alert">
        Adding new makers/studios is suspended until further notice.
    </div>

    <div class="card border-primary my-5 w-75 mx-auto">
        <div class="card-body">
            <h5 class="card-title">
                Please do not contact me if you are looking for a fursuit
            </h5>

            <p class="card-text">
                I am sorry, but I can provide support only for fursuit makers. I am not a maker myself, I don't make fursuits, I am merely a "webmaster". The only thing I can do for you, is this website.
            </p>
        </div>
    </div>

    {% if not is_solved %}
        {{ form_start(form) }}
        {{ render(controller('App\\Captcha\\Controller::challenge', {form: form.captcha})) }}
        <input type="submit" class="btn btn-primary my-1 btn-sm" value="Reveal email address">
        {{ form_end(form) }}
    {% endif %}

    <p class="text-center">
        <a class="btn btn-primary my-1 btn-sm" href="https://www.tumblr.com/getfursuit">
            <i class="fa-brands fa-tumblr"></i> Tumblr
        </a>
        <a class="btn btn-primary my-1 btn-sm" rel="me" href="https://fursuits.online/@getfursuit">
            <i class="fa-brands fa-mastodon"></i> Mastodon
        </a>
        <a class="btn btn-primary my-1 btn-sm" rel="me" href="https://bsky.app/profile/getfursuit.bsky.social">
            <i class="fa-brands fa-bluesky"></i> Bluesky
        </a>
        <a class="btn btn-primary my-1 btn-sm" href="https://www.instagram.com/getfursu.it/">
            <i class="fa-brands fa-instagram"></i> Instagram
        </a>
        <a class="btn btn-primary my-1 btn-sm" href="https://twitter.com/getfursuit">
            <i class="fa-brands fa-twitter"></i> Twitter
        </a>

        {% if is_solved %}
            <br>

            <a href="mailto:{{ contact_email }}" class="btn btn-info my-1 btn-sm">
                <i class="fas fa-envelope"></i> {{ contact_email }}
            </a>
        {% endif %}
    </p>

    <p class="text-center">
        You can also ask on FursuitReview's Discord server (search for <em>#getfursuit</em> channel): <br>

        <a class="btn btn-primary my-1 btn-sm" href="https://discord.gg/mep6nUy">
            <i class="fab fa-discord"></i> Discord (FSR's server)
        </a>
    </p>
{% endblock %}
